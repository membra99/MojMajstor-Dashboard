@model List<Universal.DTO.ODTO.ProblemODTO>
@using Universal.DTO.ODTO

@{
    ViewData["Title"] = "All Problems";
}

<!-- Problem Detail Modal -->
<div class="modal fade" id="problemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Problem Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="problemModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="d-flex align-items-center gap-2 me-auto">
                    <label class="form-label mb-0 fw-bold">Status:</label>
                    <select id="modalStatusSelect" class="form-select form-select-sm" style="width:150px;"></select>
                    <button class="btn btn-dotnet btn-sm" id="modalSaveStatus">Save</button>
                    <span id="modalStatusMsg" class="text-success small" style="display:none;">Saved!</span>
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h5 class="m-0">Reported Problems</h5>
            </div>
            <div class="card-body">
                <table id="problemsTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Email</th>
                            <th>App Version</th>
                            <th>OS</th>
                            <th>OS Version</th>
                            <th>Device ID</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var problem in Model)
                        {
                            <tr>
                                <td>@problem.ProblemID</td>
                                <td>@problem.Email</td>
                                <td>@problem.AppVersion</td>
                                <td>@problem.Os</td>
                                <td>@problem.OsVersion</td>
                                <td>@problem.DeviceID</td>
                                <td>
                                    @{
                                        var badgeClass = problem.Status switch
                                        {
                                            ProblemStatus.Open => "bg-danger",
                                            ProblemStatus.InProgress => "bg-warning text-dark",
                                            ProblemStatus.Resolved => "bg-success",
                                            ProblemStatus.Closed => "bg-secondary",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@problem.Status</span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary btn-view-problem"
                                            data-id="@problem.ProblemID"
                                            title="View Details">
                                        <i class="fas fa-eye"></i> View
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var allStatuses = ['Open', 'InProgress', 'Resolved', 'Closed'];
    var currentProblemId = null;

    $(document).ready(function () {
        $('#problemsTable').DataTable({
            "order": [[0, "desc"]],
            "info": true,
            "searching": true
        });

        // Populate status dropdown
        allStatuses.forEach(function (s) {
            $('#modalStatusSelect').append('<option value="' + s + '">' + s + '</option>');
        });

        // Open modal on button click
        $(document).on('click', '.btn-view-problem', function () {
            currentProblemId = $(this).data('id');
            $('#problemModalBody').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>');
            $('#modalStatusMsg').hide();
            $('#problemModal').modal('show');

            $.getJSON('/Dashboard/ProblemDetails?id=' + currentProblemId, function (data) {
                if (data.error) {
                    $('#problemModalBody').html('<div class="alert alert-danger">Error: ' + data.error + '</div>');
                    return;
                }

                // Set status dropdown
                $('#modalStatusSelect').val(data.status);

                var html = '<div class="row">';

                // Left column - info
                html += '<div class="col-md-6">';
                html += '<h6 class="text-muted border-bottom pb-1 mb-2">Info</h6>';
                html += '<dl class="row mb-3">';
                html += '<dt class="col-5">Email</dt><dd class="col-7">' + (data.email || '-') + '</dd>';
                html += '<dt class="col-5">App Version</dt><dd class="col-7">' + (data.appVersion || '-') + '</dd>';
                html += '<dt class="col-5">OS</dt><dd class="col-7">' + (data.os || '-') + '</dd>';
                html += '<dt class="col-5">OS Version</dt><dd class="col-7">' + (data.osVersion || '-') + '</dd>';
                html += '<dt class="col-5">Device ID</dt><dd class="col-7">' + (data.deviceID || '-') + '</dd>';
                html += '</dl>';
                html += '<h6 class="text-muted border-bottom pb-1 mb-2">Description</h6>';
                html += '<p class="fw-bold mb-1">Actual Behavior</p><p>' + (data.actualBehavior || '-') + '</p>';
                html += '<p class="fw-bold mb-1">Expected Behavior</p><p>' + (data.expectedBehavior || '-') + '</p>';
                html += '<p class="fw-bold mb-1">Steps to Reproduce</p><p style="white-space:pre-wrap">' + (data.stepsToReproduce || '-') + '</p>';
                html += '</div>';

                // Right column - media
                html += '<div class="col-md-6">';

                if (data.screenshotUrls && data.screenshotUrls.length > 0) {
                    html += '<h6 class="text-muted border-bottom pb-1 mb-2">Screenshots (' + data.screenshotUrls.length + ')</h6>';
                    html += '<div class="row g-2 mb-3">';
                    data.screenshotUrls.forEach(function (url) {
                        html += '<div class="col-6"><a href="' + url + '" target="_blank">';
                        html += '<img src="' + url + '" class="img-fluid rounded border" style="max-height:150px;object-fit:cover;width:100%;" onerror="this.parentElement.parentElement.innerHTML=\'<div class=&quot;text-danger small p-2&quot;>Image failed to load</div>\'">';
                        html += '</a></div>';
                    });
                    html += '</div>';
                } else {
                    html += '<p class="text-muted small">No screenshots.</p>';
                }

                if (data.videoUrl) {
                    html += '<h6 class="text-muted border-bottom pb-1 mb-2">Video</h6>';
                    html += '<video controls class="w-100 rounded" style="max-height:300px;">';
                    html += '<source src="' + data.videoUrl + '">';
                    html += '</video>';
                } else {
                    html += '<p class="text-muted small">No video.</p>';
                }

                html += '</div></div>'; // col + row

                $('#problemModalBody').html(html);
            }).fail(function (xhr) {
                $('#problemModalBody').html('<div class="alert alert-danger">Failed to load problem. Status: ' + xhr.status + '<br>' + xhr.responseText + '</div>');
            });
        });

        // Save status
        $('#modalSaveStatus').on('click', function () {
            if (!currentProblemId) return;
            var status = $('#modalStatusSelect').val();
            $.post('/Dashboard/UpdateProblemStatus', { id: currentProblemId, status: status }, function (res) {
                if (res.success) {
                    $('#modalStatusMsg').show().delay(2000).fadeOut();
                    // Update badge in table
                    var badgeMap = { Open: 'bg-danger', InProgress: 'bg-warning text-dark', Resolved: 'bg-success', Closed: 'bg-secondary' };
                    var btn = $('.btn-view-problem[data-id="' + currentProblemId + '"]');
                    var badge = btn.closest('tr').find('.badge');
                    badge.attr('class', 'badge ' + (badgeMap[status] || 'bg-secondary')).text(status);
                }
            });
        });
    });
</script>
}
