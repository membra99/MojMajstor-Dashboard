@model Universal.DTO.ODTO.ProblemODTO
@using Universal.DTO.ODTO

@{
    ViewData["Title"] = "Problem Details";
    var badgeClass = Model.Status switch
    {
        ProblemStatus.Open => "bg-danger",
        ProblemStatus.InProgress => "bg-warning text-dark",
        ProblemStatus.Resolved => "bg-success",
        ProblemStatus.Closed => "bg-secondary",
        _ => "bg-secondary"
    };
}

<div class="row">
    <div class="col-lg-8">

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="m-0">Problem #@Model.ProblemID</h5>
                <span class="badge @badgeClass fs-6">@Model.Status</span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@(Model.Email ?? "-")</dd>

                    <dt class="col-sm-4">App Version</dt>
                    <dd class="col-sm-8">@(Model.AppVersion ?? "-")</dd>

                    <dt class="col-sm-4">OS</dt>
                    <dd class="col-sm-8">@(Model.Os ?? "-")</dd>

                    <dt class="col-sm-4">OS Version</dt>
                    <dd class="col-sm-8">@(Model.OsVersion ?? "-")</dd>

                    <dt class="col-sm-4">Device ID</dt>
                    <dd class="col-sm-8">@(Model.DeviceID ?? "-")</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><h5 class="m-0">Description</h5></div>
            <div class="card-body">
                <h6 class="text-muted">Actual Behavior</h6>
                <p>@(Model.ActualBehavior ?? "-")</p>

                <h6 class="text-muted">Expected Behavior</h6>
                <p>@(Model.ExpectedBehavior ?? "-")</p>

                <h6 class="text-muted">Steps to Reproduce</h6>
                <p style="white-space: pre-wrap;">@(Model.StepsToReproduce ?? "-")</p>
            </div>
        </div>

        @if (Model.ScreenshotUrls.Any())
        {
            <div class="card mb-4">
                <div class="card-header"><h5 class="m-0">Screenshots</h5></div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var url in Model.ScreenshotUrls)
                        {
                            <div class="col-6 col-md-4">
                                <a href="@url" target="_blank">
                                    <img src="@url"
                                         class="img-fluid rounded border"
                                         style="max-height: 200px; object-fit: cover; width: 100%;"
                                         alt="Screenshot"
                                         onerror="this.parentElement.innerHTML='<span class=&quot;text-danger small&quot;>Failed to load image</span>'" />
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.Screenshots))
        {
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning text-dark"><h5 class="m-0">Screenshots</h5></div>
                <div class="card-body text-muted">
                    Could not load screenshots from S3. Key: <code>@Model.Screenshots</code>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.VideoUrl))
        {
            <div class="card mb-4">
                <div class="card-header"><h5 class="m-0">Video</h5></div>
                <div class="card-body text-center">
                    <video controls class="w-100 rounded" style="max-height: 480px;">
                        <source src="@Model.VideoUrl" />
                        Your browser does not support video playback.
                    </video>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.Video))
        {
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning text-dark"><h5 class="m-0">Video</h5></div>
                <div class="card-body text-muted">
                    Could not load video from S3. Key: <code>@Model.Video</code>
                </div>
            </div>
        }

    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header"><h5 class="m-0">Update Status</h5></div>
            <div class="card-body">
                <form asp-action="UpdateProblemStatus" asp-controller="Dashboard" method="post">
                    <input type="hidden" name="id" value="@Model.ProblemID" />
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select">
                            @foreach (ProblemStatus s in Enum.GetValues(typeof(ProblemStatus)))
                            {
                                <option value="@s" selected="@(s == Model.Status ? "selected" : null)">@s</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-dotnet w-100">Save Status</button>
                </form>
            </div>
        </div>

        <div class="mt-3">
            <a href="@Url.Action("AllProblems", "Dashboard")" class="btn btn-secondary w-100">
                <i class="fas fa-arrow-left me-1"></i> Back to Problems
            </a>
        </div>
    </div>
</div>
