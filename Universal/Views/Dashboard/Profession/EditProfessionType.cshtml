@model Universal.DTO.IDTO.ProfessionTypeIDTO
@using System.Text.Json

@{
    ViewData["Title"] = "Edit Sub-Profession";
    var professions = ViewBag.Professions as List<Universal.DTO.ODTO.ProfessionODTO>;
    var translations = new Dictionary<string, string>();
    if (!string.IsNullOrEmpty(Model.Translations))
    {
        translations = JsonSerializer.Deserialize<Dictionary<string, string>>(Model.Translations) ?? new();
    }
    var translationsJson = JsonSerializer.Serialize(translations);
}

<div class="container bg-light w-50">
    <div class="text-center">
        <h2>Edit Sub-Profession</h2>
    </div>
    @using (Html.BeginForm("EditProfessionTypeModel", "Dashboard", FormMethod.Post))
    {
        <div class="mb-3">
            @Html.HiddenFor(model => model.ProfessionTypeId)
            @Html.HiddenFor(model => model.Translations)
        </div>
        <div class="form-group mb-3">
            @Html.LabelRequiredFor(model => model.ProfessionId, "Profession:", true)
            @Html.DropDownListFor(model => model.ProfessionId,
                new SelectList(professions, "ProfessionId", "ProfessionName"),
                "Select Profession",
                new { @class = "form-control", disabled = "disabled" })
            @Html.HiddenFor(model => model.ProfessionId)
            @Html.ValidationMessageFor(model => model.ProfessionId, null, new { @class = "text-danger" })
        </div>
        <div class="form-group mb-3">
            @Html.LabelRequiredFor(model => model.ProfessionTypeName, "Sub-profession name:", true)
            @Html.TextBoxFor(model => model.ProfessionTypeName, new { @class = "form-control", placeholder = "Sub-Profession Name" })
            @Html.ValidationMessageFor(model => model.ProfessionTypeName, null, new { @class = "text-danger" })
        </div>
        @if (translations.Any())
        {
            <div class="form-group mb-3">
                <label for="SelectedLanguage">Language:</label>
                <select id="SelectedLanguage" name="SelectedLanguage" class="form-control">
                    @foreach (var lang in translations)
                    {
                        <option value="@lang.Key">@lang.Key</option>
                    }
                </select>
            </div>
            <div class="form-group mb-3">
                <label for="TranslationValue">Translation:</label>
                <input type="text" id="TranslationValue" name="TranslationValue" class="form-control" />
            </div>
        }
        <div class="mx-auto mb-3 w-50">
            <input type="submit" value="Save" class="form-control p-2 btn-dotnet" />
        </div>
    }
    <script id="loadScriptDynamic" type="text/template">
        var translationData = @Html.Raw(translationsJson);
        var langSelect = document.getElementById('SelectedLanguage');
        var translationInput = document.getElementById('TranslationValue');
        function updateTranslation() {
            if (langSelect && translationInput) {
                translationInput.value = translationData[langSelect.value] || '';
            }
        }
        if (langSelect) {
            langSelect.addEventListener('change', updateTranslation);
            updateTranslation();
        }
    </script>
</div>
